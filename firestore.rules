rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEUROBUDGET SECURITY RULES (PROTOTYPING MODE)
     *
     * Core Philosophy:
     * This ruleset enforces a strict, path-based ownership model optimized for the "NeuroBudget" 
     * cyberpunk application. Access control is tied directly to the Firebase Authentication UID, 
     * ensuring users can only interact with their own financial data.
     *
     * Data Structure:
     * All data is organized hierarchically under the path /users/{userId}. This structure 
     * segregates private user data (profiles, transactions, budgets, categories) into 
     * user-specific trees, providing high performance and simplified security logic.
     *
     * Key Security Decisions:
     * 1. Ownership Model: Every document is strictly owned by the user whose UID appears in the path.
     * 2. Denormalized Authorization: Every document contains an internal 'userId' or 'id' field 
     *    matching the path. This allows the rules to verify ownership without additional 
     *    'get()' calls, keeping operations fast and cheap.
     * 3. Relational Integrity: On creation, the rules force the client to set internal ownership 
     *    fields to match the authenticated user.
     * 4. Immutability: Ownership fields are made immutable on update, preventing data from 
     *    being "stolen" or reassigned to other users.
     * 5. Prototyping Flexibility: While authorization (WHO can access) is strictly enforced, 
     *    data shape validation (WHAT the data looks like) is omitted to allow for rapid UI iteration.
     */

    // --- Helper Functions ---

    /** Checks if the request is coming from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId from the path. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Combines ownership check with a check for the document's existence for safe updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile document. Stores unique settings like currency and avatar.
     * @path /users/{userId}/profile
     * @allow (get) Authenticated user 'user_123' reading /users/user_123/profile
     * @deny (create) Authenticated user 'user_123' creating a profile for 'user_456'
     * @principle Enforces document ownership and validates that the internal ID matches the auth UID.
     */
    match /users/{userId}/profile {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for user transactions. Segregated by user for privacy.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (list) User listing only their own transactions under their specific UID path.
     * @deny (update) User attempting to change the 'userId' field on an existing transaction.
     * @principle Path-based segregation and immutable relational links.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for user-defined budgets and spending limits.
     * @path /users/{userId}/budgets/{budgetId}
     * @allow (create) User 'user_123' adding a budget with 'userId' set to 'user_123'.
     * @deny (get) User 'user_abc' attempting to read a budget belonging to 'user_xyz'.
     * @principle Restricts access to a user's own data tree via path wildcards.
     */
    match /users/{userId}/budgets/{budgetId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for custom spending categories defined by the user.
     * @path /users/{userId}/spendingCategories/{categoryId}
     * @allow (delete) User removing one of their own custom categories.
     * @deny (create) A request where the 'userId' in the data does not match the 'userId' in the path.
     * @principle Ensures relational integrity between the document data and its storage path.
     */
    match /users/{userId}/spendingCategories/{categoryId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

  }
}