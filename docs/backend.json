
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User profile data stored in Firestore.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string", "format": "uri" },
        "currency": { "type": "string", "default": "INR" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "avatar", "currency", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "A financial transaction record.",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "desc": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "recurring": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "category", "desc", "date", "recurring", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "type": "object",
      "description": "Budget limit for a category.",
      "properties": {
        "limit": { "type": "number" },
        "alertAt": { "type": "number", "description": "Percentage at which to alert (e.g., 80)" }
      },
      "required": ["limit", "alertAt"]
    }
  },
  "auth": {
    "providers": ["github"]
  },
  "firestore": {
    "/users/{userId}/profile": {
      "schema": "UserProfile",
      "description": "User's private profile document."
    },
    "/users/{userId}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Individual transaction records."
    },
    "/users/{userId}/budgets/{categoryId}": {
      "schema": "Budget",
      "description": "Budget limits per category."
    }
  }
}
